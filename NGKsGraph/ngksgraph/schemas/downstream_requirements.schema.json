{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"additionalProperties": false,
	"required": ["repo_root", "requirements", "status"],
	"properties": {
		"repo_root": {"type": "string", "minLength": 1},
		"status": {"type": "string", "enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL_CLOSED"]},
		"requirements": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"subproject_id",
					"requirement_id",
					"source_detector",
					"category",
					"description",
					"required_tools",
					"required_minimums",
					"required_flags",
					"required_env",
					"severity_if_missing",
					"confidence"
				],
				"properties": {
					"subproject_id": {"type": "string", "minLength": 1},
					"requirement_id": {"type": "string", "minLength": 1},
					"source_detector": {"type": "string", "minLength": 1},
					"category": {"type": "string", "minLength": 1},
					"description": {"type": "string", "minLength": 1},
					"required_tools": {"type": "array", "items": {"type": "string"}},
					"required_minimums": {"type": "object"},
					"required_flags": {
						"type": "object",
						"additionalProperties": {
							"type": "array",
							"items": {"type": "string"}
						}
					},
					"required_env": {"type": "array", "items": {"type": "string"}},
					"severity_if_missing": {"type": "string", "minLength": 1},
					"confidence": {"type": "number", "minimum": 0, "maximum": 1}
				}
			}
		}
	}
}
