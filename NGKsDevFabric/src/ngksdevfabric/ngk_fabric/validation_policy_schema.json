{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevFabEco Validation Policy",
  "type": "object",
  "required": ["schema_version", "plugins"],
  "properties": {
    "schema_version": {"type": "string"},
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "plugin_name",
          "plugin_category",
          "trigger_stages",
          "required_artifact_types",
          "required_project_capabilities",
          "required_languages",
          "required_target_types",
          "mode",
          "severity",
          "default_enabled",
          "blocking_stages",
          "advisory_stages"
        ],
        "properties": {
          "plugin_name": {"type": "string"},
          "plugin_category": {"type": "string"},
          "trigger_stages": {"type": "array", "items": {"type": "string"}},
          "required_artifact_types": {"type": "array", "items": {"type": "string"}},
          "required_project_capabilities": {"type": "array", "items": {"type": "string"}},
          "required_languages": {"type": "array", "items": {"type": "string"}},
          "required_target_types": {"type": "array", "items": {"type": "string"}},
          "mode": {"type": "string"},
          "severity": {"type": "string"},
          "default_enabled": {"type": "boolean"},
          "blocking_stages": {"type": "array", "items": {"type": "string"}},
          "advisory_stages": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
