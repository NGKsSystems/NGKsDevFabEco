{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ngks.outcome_feedback.record.v1",
  "title": "NGKs Outcome Feedback Record",
  "type": "object",
  "required": [
    "feedback_version",
    "run_id",
    "parent_run_id",
    "stage_id",
    "stage_name",
    "linked_envelope_hash",
    "feedback_sequence_index",
    "timestamp_utc",
    "action_id",
    "action_proposed",
    "action_taken",
    "action_executor",
    "action_timestamp_utc",
    "observed_result_code",
    "observed_result_summary",
    "observed_gate_change",
    "confidence_adjustment_delta",
    "confidence_adjustment_reason",
    "recurrence_impact_category",
    "recurrence_impact_delta",
    "predictive_calibration_delta",
    "predictive_calibration_reason",
    "certification_impact",
    "supporting_evidence_refs",
    "previous_feedback_hash",
    "feedback_hash",
    "ruleset_version"
  ],
  "properties": {
    "feedback_version": {"type": "string", "const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "parent_run_id": {"type": ["string", "null"]},
    "stage_id": {"type": "string", "minLength": 1},
    "stage_name": {"type": "string", "minLength": 1},
    "linked_envelope_hash": {"type": "string", "minLength": 1},
    "feedback_sequence_index": {"type": "integer", "minimum": 1},
    "timestamp_utc": {"type": "string"},
    "action_id": {"type": "string", "minLength": 1},
    "action_proposed": {"type": "boolean"},
    "action_taken": {"type": "boolean"},
    "action_executor": {"type": "string", "enum": ["system", "operator", "mixed"]},
    "action_timestamp_utc": {"type": "string"},
    "observed_result_code": {"type": "string", "minLength": 1},
    "observed_result_summary": {"type": "string", "minLength": 1},
    "observed_gate_change": {"type": "string", "minLength": 1},
    "confidence_adjustment_delta": {"type": "number", "minimum": -0.05, "maximum": 0.05},
    "confidence_adjustment_reason": {"type": "string", "minLength": 1},
    "recurrence_impact_category": {"type": "string", "enum": ["reduced", "unchanged", "increased"]},
    "recurrence_impact_delta": {"type": "number"},
    "predictive_calibration_delta": {"type": "number"},
    "predictive_calibration_reason": {"type": "string", "minLength": 1},
    "certification_impact": {"type": "string", "minLength": 1},
    "supporting_evidence_refs": {"type": "array", "items": {"type": "string"}},
    "previous_feedback_hash": {"type": "string", "minLength": 1},
    "feedback_hash": {"type": "string", "minLength": 1},
    "ruleset_version": {"type": "string", "minLength": 1},
    "writer_runtime_ms": {"type": "number"},
    "local_path_variants": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
